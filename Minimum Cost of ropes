class Solution {
    public static int minCost(int[] arr) {
        // code here
        PriorityQueue <Integer> pq = new PriorityQueue<>();
        for(int a:arr)
        {
            pq.add(a);
        }
        int cost = 0;
        while(pq.size() > 1)
        {
            int first = pq.poll();
            int second = pq.poll();
            int sum = first + second;
            cost += sum;
            pq.add(sum);
        }
        return cost;
    }
}
