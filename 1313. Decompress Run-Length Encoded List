class Solution {
    public int[] decompressRLElist(int[] nums) {
        List<Integer> li = new ArrayList<>();
        int n = nums.length;
        for(int i = 0;  i < n; i+=2)
        {
            int freq = nums[i];
            int val = nums[i+1];
            for(int j = 0; j < freq; j++)
            {
                li.add(val);
            }
        }
        int[] result = new int[li.size()];
        for(int i = 0; i < li.size(); i++)
        {
            result[i] = li.get(i);
        }
        return result;
    }
}
